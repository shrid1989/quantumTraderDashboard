# QuantumTrader Dashboard - Backend Environment Variables
# Copy this file to .env and fill in your Supabase values

# Supabase (get from Supabase Dashboard → Project Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-public-key-here

# App
IS_LOCAL=true
DEBUG=true

# Auth (single user) — set these in your actual .env, never commit real values
JWT_SECRET=change-this-to-a-long-random-string-in-production
USER_EMAIL=your-login-email@example.com
USER_PASSWORD=your-secure-password

# S3 (used by Lambda, not required for local dev)
S3_BUCKET=shri-trading-logs

# Production only: Vercel frontend URL (for CORS)
# FRONTEND_URL=https://your-app.vercel.app
